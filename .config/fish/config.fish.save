# --- STILE MIST_CYBER ---

function fish_prompt
    # Salva lo stato dell'ultimo comando (per il colore della lambda)
    set -l last_status $status
    
    # Definizione colori (utilizzando i nomi standard di fish)
    set -l blue (set_color blue)
    set -l cyan (set_color cyan)
    set -l red (set_color red)
    set -l normal (set_color normal)

    # 1. Prima riga: ┌──( user@host )-[ cartella ]
    echo -n -s $blue "┌──(" $cyan $USER "@" (prompt_hostname) $blue ")-[" $normal (basename (pwd)) $blue "]" \n

    # 2. Seconda riga: └─ Mar 10 Ott 10:42:53 ~ dev
    echo -n -s $blue "└─ " $cyan (date "+%a %d %b %H:%M:%S") " ~ dev" \n

    # 3. Terza riga: Simbolo λ (Blu se OK, Rosso se errore)
    echo -n "  "
    if test $last_status -eq 0
        echo -n -s $blue "λ " $normal
    else
        echo -n -s $red "λ " $normal
    end
end

# Se vuoi disabilitare il messaggio iniziale di CachyOS (fastfetch)
function fish_greeting
endsource /usr/share/cachyos-fish-config/cachyos-config.fish

